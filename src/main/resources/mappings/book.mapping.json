{
  "$schema": "../../../../mappings.schema.json",
  "primaryKey": "id",
  "root": {
    "materialType": {
      "type": "string",
      "destinationField": "material_type"
    },
    "title": {
      "type": "freetext",
      "destinationField": "book_title"
    },
    "author": {
      "type": "string",
      "destinationField": "book_author"
    },
    "year": {
      "type": "number",
      "destinationField": "book_year"
    },
    "publishedAt": {
      "type": "datetime",
      "destinationField": "book_published_at"
    },
    "chapters": {
      "type": "subdocument",
      "subdocumentType": "chapter",
      "destinationField": "chapters"
    }
  },
  "chapter": {
    "title": {
      "type": "freetext",
      "destinationField": "chapters.title"
    },
    "pageCount": {
      "type": "number",
      "destinationField": "chapters.page_count"
    }
  }
}
