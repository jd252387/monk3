{
  "$schema": "./mappings.schema.json",
  "primaryKey": "id",
  "root": {
    "itemName": {
      "type": "string",
      "destinationField": "item_name",
      "sourcing": {
        "default-datasource": ".[\"item-name\"]",
        "s3-audio": { "jq": ".item_name", "required": false }
      }
    },
    "itemContent": {
      "type": "freetext",
      "destinationField": "item_content",
      "sourcing": {
        "default-datasource": { "jq": ".[\"item-content\"]", "partialUpdate": "set" },
        "s3-audio": { "jq": ".[\"item-content\"]", "required": false }
      }
    },
    "timestamp": {
      "type": "datetime",
      "destinationField": "timestamp",
      "sourcing": {
        "default-datasource": ".timestamp",
        "s3-audio": { "jq": ".timestamp", "required": false }
      }
    },
    "subItems": {
      "type": "subdocument",
      "subdocumentType": "subItems",
      "destinationField": "subItems",
      "primaryKey": {
        "default-datasource": ".subItems[].name"
      },
      "partialUpdate": {
        "default-datasource": "set"
      }
    }
  },
  "subItems": {
    "subItemName": {
      "type": "string",
      "destinationField": "item_name",
      "sourcing": {
        "default-datasource": ".subItems[].itemName",
        "s3-audio": { "jq": ".subItems[].name", "required": false }
      }
    },
    "subItemContent": {
      "type": "freetext",
      "destinationField": "item_content",
      "sourcing": {
        "default-datasource": ".subItems[].itemContent"
      }
    }
  }
}
