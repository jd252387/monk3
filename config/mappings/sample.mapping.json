{
  "$schema": "./mappings.schema.json",
  "root": {
    "identifier": {"field": "title", "data": {"type": "text", "phrases": [{"type": "phrase", "value": "book"}]}},
    "materialType": {
      "type": "string",
      "destinationField": "material_type"
    },
    "title": {
      "type": "freetext"
    },
    "category": {
      "type": "string",
      "aggregatable": true
    },
    "price": {
      "type": "number"
    },
    "description": {
      "type": "freetext"
    },
    "year": {
      "type": "datetime"
    },
    "subdocuments": {
      "type": "subdocument",
      "subdocumentType": "subdoc",
      "destinationField": "subdocs"
    }
  }, 
  "subdoc": {
    "chapter": {
      "type": "string",
      "destinationField": "chapter", 
      "aggregatable": true
    },
    "page": {
      "type": "number",
      "destinationField": "page"
    }
  }
}
