{
  "$schema": "./virtual-mapping.schema.json",
  "root": {
    "recentBook": {
      "type": "freetext",
      "expansion": {
        "field": "",
        "data": [
          {"field": "title", "bool": "must", "data": "{{data}}"},
          {"field": "year", "bool": "must", "data": {"type": "range", "gte": 2010, "lte": 2025}}
        ]
      }
    },
    "twentyFirstCentury": {
      "type": "predicate",
      "expansion": {
        "field": "year",
        "data": {"type": "range", "gte": 2000}
      }
    },
    "chapterSubquery": {
      "type": "subquery",
      "expansion": {
        "field": "chapters",
        "data": "{{data}}"
      }
    }
  },
  "chapter": {
    "shortChapter": {
      "type": "number",
      "expansion": {
        "field": "pageCount",
        "data": "{{data}}"
      }
    }
  }
}