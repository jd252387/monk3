{
  "$schema": "./mappings.schema.json",
  "root": {
    "materialType": {
      "type": "string",
      "destinationField": "material_type",
      "aggregatable": true
    },
    "title": {
      "type": "freetext",
      "destinationField": "article_headline",
      "morphologies": {
        "english": "article_headline_en"
      }
    },
    "body": {
      "type": "freetext",
      "destinationField": "article_body"
    },
    "year": {
      "type": "number",
      "destinationField": "article_year",
      "aggregatable": true
    },
    "publishedAt": {
      "type": "datetime",
      "destinationField": "article_published_at",
      "aggregatable": true
    },
    "citationCount": {
      "type": "number",
      "destinationField": "article_citation_count"
    },
    "openAccess": {
      "type": "boolean",
      "destinationField": "article_open_access"
    },
    "embedding": {
      "type": "vector",
      "destinationField": "article_vector_%i",
      "start": 1,
      "end": 2
    }
  }
}
