{
  "backends": {
    "elastic-books": {
      "engine": "ELASTICSEARCH",
      "url": "http://localhost:9200",
      "index": "books",
      "primaryKey": "id",
      "physical": "config/mappings/book.mapping.json",
      "virtual": "config/mappings/book.virtual.json",
      "defaultSize": 10
    },
    "solr-books": {
      "engine": "SOLR",
      "url": "http://localhost:8983/solr",
      "collection": "books",
      "primaryKey": "id",
      "physical": "config/mappings/book.mapping.json",
      "virtual": "config/mappings/book.virtual.json",
      "defaultSize": 10
    },
    "solr-articles": {
      "engine": "SOLR",
      "url": "http://localhost:8983/solr",
      "collection": "articles",
      "primaryKey": "id",
      "physical": "config/mappings/article.mapping.json",
      "defaultSize": 20
    },
    "elastic-datasets": {
      "engine": "ELASTICSEARCH",
      "url": "http://localhost:9200",
      "index": "datasets",
      "primaryKey": "id",
      "physical": "config/mappings/dataset.mapping.json",
      "defaultSize": 10
    },
    "solr-collection-text": {
      "engine": "SOLR",
      "zk": "localhost:2181",
      "chroot": "/solr",
      "collection": "text",
      "primaryKey": "id",
      "physical": "config/mappings/document.mapping.json"
    },
    "solr-collection-text-small": {
      "engine": "SOLR",
      "zk": "zk-solr:2181",
      "collection": "small-text"
    },
    "elastic-index-text": {
      "engine": "ELASTICSEARCH",
      "hosts": ["http://es01:9200", "http://es02:9200"],
      "index": "index-text"
    },
    "elastic-index-text-semantic": {
      "engine": "ELASTICSEARCH",
      "hosts": ["http://es01:9200", "http://es02:9200"],
      "index": "index-semantic"
    }
  }
}
