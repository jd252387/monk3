{
  "backends": {
    "elastic-books": {
      "engine": "ELASTICSEARCH",
      "url": "http://localhost:9200",
      "index": "books",
      "defaultSize": 10
    },
    "solr-articles": {
      "engine": "SOLR",
      "url": "http://localhost:8983/solr",
      "collection": "articles",
      "defaultSize": 20
    }
  }
}
