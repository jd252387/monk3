{
  "mappings": {
    "book": {
      "backend": "solr-books",
      "filter": {
        "field": "materialType",
        "data": { "type": "text", "phrases": [{ "type": "phrase", "value": "book" }] }
      },
      "routing": [
        {
          "conditions": [
            { "type": "datetimeRangeWithin", "field": "publishedAt", "period": "P30D" }
          ],
          "backend": "solr-books"
        }
      ]
    },
    "article": {
      "backend": "solr-articles",
      "filter": {
        "field": "materialType",
        "data": { "type": "text", "phrases": [{ "type": "phrase", "value": "article" }] }
      }
    },
    "ds": {
      "backend": "elastic-datasets",
      "filter": {
        "field": "materialType",
        "data": { "type": "text", "phrases": [{ "type": "phrase", "value": "ds" }] }
      }
    },
    "document": { "backend": "solr-collection-text" }
  }
}
