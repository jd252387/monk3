{
  "$schema": "./mappings.schema.json",
  "root": {
    "identifier": {
      "field": "materialType",
      "data": { "type": "text", "phrases": [{ "type": "phrase", "value": "book" }] }
    },
    "materialType": {
      "type": "string",
      "destinationField": "material_type"
    },
    "title": {
      "type": "freetext",
      "destinationField": "book_title",
      "morphologies": {
        "english": "book_title_en"
      }
    },
    "author": {
      "type": "string",
      "destinationField": "book_author",
      "aggregatable": true
    },
    "year": {
      "type": "number",
      "destinationField": "book_year",
      "aggregatable": true,
      "sortable": true
    },
    "publishedAt": {
      "type": "datetime",
      "destinationField": "book_published_at",
      "aggregatable": true
    },
    "inPrint": {
      "type": "boolean",
      "destinationField": "book_in_print"
    },
    "popularity": {
      "type": "number",
      "destinationField": "book_popularity",
      "searchable": false,
      "aggregatable": true,
      "sortable": true
    },
    "internalNotes": {
      "type": "freetext",
      "destinationField": "book_internal_notes",
      "fetchable": false
    },
    "embedding": {
      "type": "vector",
      "destinationField": "vector_%i",
      "start": 1,
      "end": 3
    },
    "chapters": {
      "type": "subdocument",
      "subdocumentType": "chapter",
      "destinationField": "chapters"
    }
  },
  "chapter": {
    "title": {
      "type": "freetext"
    },
    "pageCount": {
      "type": "number",
      "destinationField": "page_count",
      "aggregatable": true
    },
    "pages": {
      "type": "subdocument",
      "subdocumentType": "page",
      "destinationField": "pages"
    }
  }, 
  "page": {
    "content": {
      "type": "freetext",
      "destinationField": "content"
    },
    "num_words": {
      "type": "number",
      "destinationField": "num_words",
      "aggregatable": true
    }
  }
}
